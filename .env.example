# =========================================================================
# eBay Multi-Channel Lister - Environment Configuration Template
# Copy this file to '.env' and fill in your actual API credentials.
# =========================================================================

# ── Local Server ──
# Dashboard listen port (must match Chrome extension host_permissions if changed)
PORT=45900

# ── API Key Authentications ──
# Local Chrome Extension access token (used to secure background scrape communications)
API_KEY=lister-secret-key-12345

# Google Gemini AI API key (for vision analysis & metadata schema correction)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth Sign-In Settings ──
# (Enable premium authentication routing. Leave empty to bypass in development mode)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:45900/api/auth/google/callback

# ── Stripe Payment Billing Webhook Settings ──
# (Used to manage premium subscriptions. Leave empty to bypass checkouts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── eBay Integration Credentials ──
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_REFRESH_TOKEN=your_ebay_user_refresh_token
EBAY_LOCATION_KEY=default

# eBay listing policy overrides (Optional - will auto-generate policy defaults if left blank)
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# ── Shopify Store Sync Integration ──
SHOPIFY_SHOP_NAME=your-shopify-store-subdomain
SHOPIFY_ACCESS_TOKEN=shpat_your_shopify_access_token

# ── WooCommerce Shop Integration ──
WOOCOMMERCE_URL=https://your-woocommerce-store.com
WOOCOMMERCE_KEY=ck_your_woo_consumer_key
WOOCOMMERCE_SECRET=cs_your_woo_consumer_secret

# ── Etsy Shop Integration ──
ETSY_SHOP_ID=your_etsy_shop_id
ETSY_ACCESS_TOKEN=your_etsy_oauth_access_token
ETSY_CLIENT_ID=your_etsy_api_keystring

# ── Image Editing & Sourcing Configuration ──
# Text watermark overlay details (PowerShell GDI+ sprucing)
WATERMARK_TEXT=Store Name

# ── Lister Preferences & Default Polices ──
SKU_PREFIX=AUTO-
DEFAULT_PRICING_STRATEGY=MARKET
DEFAULT_SHIPPING_OPTION=USPS_GROUND
DEFAULT_RETURN_OPTION=NO_RETURNS
DEFAULT_IMMEDIATE_PAYMENT=true
SELLER_SHIPPING_TERMS=Shipped next business day with tracking!
SELLER_RETURN_TERMS=No returns accepted unless item is not as described.
